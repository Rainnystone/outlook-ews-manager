# ===== 发件（SMTP，账号密码直连）=====
SMTP_HOST=smtp.partner.outlook.cn
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@yourcompany.com
SMTP_PASS=你的邮箱密码
SMTP_FROM=you@yourcompany.com

# ===== 收件（EWS + OAuth，适用于 IMAP 被禁用的世纪互联 M365）=====
EWS_USER=you@yourcompany.com
EWS_CLIENT_ID=04b07795-8ddb-461a-bbee-02f9e1bf7b46
# refresh token 不放在这里：填好本文件后运行 scripts/setup.py，
# 一次性完成设备码授权 + SMTP 验证，token 会写入 token.json（600 权限）。
